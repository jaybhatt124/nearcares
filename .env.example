# ─────────────────────────────────────────────
# Smart Health Navigator — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Flask secret key (use a long random string in production)
SECRET_KEY=change-this-to-a-random-secret

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_health_navigator

# Admin Panel Login
ADMIN_USER=admin
ADMIN_PASS=your_strong_password

# Geoapify API Key — get free key at https://www.geoapify.com/
GEOAPIFY_KEY=your_geoapify_api_key_here
